# LadderTracker - Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Discord ───────────────────────────────────────────────────────────────────

# Webhook URL for the daily report embed (Settings > Integrations > Webhooks)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/<id>/<token>

# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Server (guild) ID - right-click server name > Copy Server ID (Developer Mode must be on)
DISCORD_GUILD_ID=123456789012345678

# Role name that can use admin commands (/run, /update-league, remove other users)
# Must match a role name exactly as it appears in your Discord server.
ADMIN_ROLE_NAME=Admin

# ── SQL Server ────────────────────────────────────────────────────────────────

# SA password used by both the SQL Server container and the app.
# Must meet SQL Server complexity: uppercase, lowercase, digit, and symbol.
SA_PASSWORD=YourStrongPassword123!

# Credentials used by the app and bot containers
SQL_USER=sa
SQL_PASS=YourStrongPassword123!

# ── Scheduler ─────────────────────────────────────────────────────────────────

# Hour of day in UTC (0-23) to run the tracker. Default: 23 (11 PM UTC)
RUN_HOUR=23

# ── Optional Overrides ────────────────────────────────────────────────────────

# Consecutive end-of-session losses before a tilt alert is posted (default: 3)
# TILT_THRESHOLD=3

# Day of week name for the weekly leaderboard field (default: Sunday)
# WEEKLY_DAY=Sunday

# Number of recent matches to pull per player for win% and streak data (default: 25)
# MATCH_LIMIT=25
